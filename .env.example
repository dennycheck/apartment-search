# Copy to .env and fill in credentials as needed.

# TravelTime (optional — company email required for signup)
# Get keys: https://account.traveltime.com → Applications → Create Application
TRAVELTIME_APP_ID=your_application_id
TRAVELTIME_API_KEY=your_api_key

# RentCast (optional — bulk NYC rental listings)
# Get key: https://rentcast.io/api
RENTCAST_API_KEY=your_rentcast_api_key
